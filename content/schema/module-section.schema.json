{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swiftlab.local/schema/module-section.json",
  "title": "SwiftLab module and section",
  "type": "object",
  "required": ["id", "title", "sections"],
  "properties": {
    "id": { "type": "string", "pattern": "^m[0-9]{2}-[a-z0-9-]+$" },
    "title": { "type": "string" },
    "level": { "type": "string", "enum": ["junior", "junior-plus", "pleno", "pleno-plus", "transversal"] },
    "lastReviewed": { "type": "string", "format": "date" },
    "sections": {
      "type": "array",
      "items": { "$ref": "#/$defs/section" }
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["id", "title", "objective", "blocks", "sources"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "estimatedMinutes": { "type": "integer", "minimum": 1 },
        "objective": { "type": "string" },
        "prerequisites": {
          "type": "array",
          "items": { "type": "string", "description": "moduleId/sectionId" }
        },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/block" }
        },
        "commonMistakes": { "type": "array", "items": { "type": "string" } },
        "tradeoffs": { "type": ["string", "null"] },
        "miniChallenge": { "type": "string" },
        "notes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "text"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
              "text": { "type": "string" }
            }
          }
        },
        "glossary": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["term", "definition"],
            "properties": {
              "term": { "type": "string" },
              "definition": { "type": "string" }
            }
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "url"],
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        }
      }
    },
    "block": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "text"],
          "properties": {
            "type": { "const": "text" },
            "text": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["type", "level", "text"],
          "properties": {
            "type": { "const": "heading" },
            "level": { "type": "integer", "minimum": 2, "maximum": 4 },
            "text": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["type", "variant", "body"],
          "properties": {
            "type": { "const": "callout" },
            "variant": { "enum": ["info", "tip", "warn", "danger"] },
            "title": { "type": "string" },
            "body": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["type", "code"],
          "properties": {
            "type": { "const": "code" },
            "language": {
              "type": "string",
              "description": "Info string do fenced Markdown (ex.: swift → class language-swift). Padrão: swift."
            },
            "code": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["type", "title", "steps"],
          "properties": {
            "type": { "const": "trace" },
            "title": { "type": "string" },
            "steps": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["label"],
                "properties": {
                  "label": { "type": "string" },
                  "detail": { "type": "string" },
                  "output": { "type": "string" }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "items"],
          "properties": {
            "type": { "const": "list" },
            "ordered": { "type": "boolean" },
            "items": { "type": "array", "items": { "type": "string" } }
          }
        },
        {
          "type": "object",
          "required": ["type", "items"],
          "properties": {
            "type": { "const": "checklist" },
            "items": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    }
  }
}
